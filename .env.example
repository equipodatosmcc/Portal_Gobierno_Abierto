# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Gobierno Abierto
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret
# Optional fallback used by some auth helpers in this project
BETTER_AUTH_SECRET=

# PostgreSQL (Docker)
POSTGRES_HOST=localhost
# If the app runs inside Docker Compose, use the service name instead:
# POSTGRES_HOST=db_gobierno_abierto
POSTGRES_PORT=5432
POSTGRES_DB=gobierno_abierto_db
POSTGRES_USER=admin_portal
POSTGRES_PASSWORD=change_me

# Connection string used by ORMs/libs (Prisma, pg, etc.)
DATABASE_URL=postgresql://admin_portal:change_me@localhost:5432/gobierno_abierto_db
# If the app runs inside Docker Compose, use:
# DATABASE_URL=postgresql://admin_portal:change_me@db_gobierno_abierto:5432/gobierno_abierto_db?schema=public

# Cloudflare Turnstile (anti-bot para formularios públicos)
# Test keys: siempre pasan validación. En prod reemplazar por claves reales de https://dash.cloudflare.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
